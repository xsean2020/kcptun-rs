# Rust build artifacts
/target/
**/target/
**/*.rs.bk

# IDE / editor settings
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python cache files (bench scripts)
__pycache__/
*.pyc

# Compiled test binaries (built from source, not committed)
/tests/kcptun-go/client
/tests/kcptun-go/server

# Cargo lock is committed for binary crates; keep it.
.omc/

# Flamegraph / sampling artifacts (regenerate via bench/profile_flamegraph.sh)
/bench/profiles/**
!/bench/profiles/.gitkeep
!/bench/profiles/README.md
!/bench/profiles/HOTSPOTS.md

# Locally built flamegraph workload helper (rustc -O)
/bench/kcptun_prof_wl
